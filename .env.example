# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL local — use this when you want tables to appear in pgAdmin.
DATABASE_URL=postgresql://aiot_user:123@localhost:5432/aiot_db
MIGRATION_DATABASE_URL=postgresql://aiot_user:123@localhost:5432/aiot_db

# SQLite — local fallback for mock data and Postman testing.
# DATABASE_URL=sqlite:///./aiot.db
# MIGRATION_DATABASE_URL=sqlite:///./aiot.db

# Supabase PostgreSQL — use later if you move to Supabase cloud.
# DATABASE_URL is used by FastAPI. Use Session Pooler if direct IPv6 is not available.
# MIGRATION_DATABASE_URL is used by Alembic. Use Direct connection when available.
# DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:5432/postgres?sslmode=require
# MIGRATION_DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ─── Server ──────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the web dashboard
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
