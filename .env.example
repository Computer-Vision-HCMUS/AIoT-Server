# Copy this file to `.env` and replace placeholder values locally.
# Never put real production credentials in this example file.

# Database: PostgreSQL local used by pgAdmin.
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>
MIGRATION_DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>

# SQLite fallback for quick offline mock testing.
# DATABASE_URL=sqlite:///./aiot.db
# MIGRATION_DATABASE_URL=sqlite:///./aiot.db

# Supabase PostgreSQL example for future cloud deployment.
# DATABASE_URL is used by FastAPI. Use Session Pooler if direct IPv6 is not available.
# MIGRATION_DATABASE_URL is used by Alembic. Use Direct connection when available.
# DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:5432/postgres?sslmode=require
# MIGRATION_DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
